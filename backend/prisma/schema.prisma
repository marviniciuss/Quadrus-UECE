datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Perfil {
  ADMIN
  GERENTE
  PO
  DEV
  TESTER
}

enum StatusCard {
  A_FAZER
  EM_ANDAMENTO
  HOMOLOGACAO
  CONCLUIDO
}

enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

enum StatusSprint {
  PLANEJAMENTO
  ATIVA
  CONCLUIDA
}

enum TipoAnexo {
  ARQUIVO
  LINK_EXTERNO
}

enum TipoAcao {
  MOVIMENTACAO
  COMENTARIO
  ALERTA
  CRIACAO
}

model Usuario {
  id_usuario    String           @id @default(uuid()) @db.Uuid
  nome          String
  email         String           @unique
  membros       MembroProjeto[]
  cards         Card[]           @relation("ResponsavelCards")
  votos         VotoPoker[]
  notificacoes  Notificacao[]    @relation("DestinoNotificacoes")
  logs          LogAcoes[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("usuarios")
}

model Projeto {
  id_projeto    String           @id @default(uuid()) @db.Uuid
  nome          String
  descricao     String?
  data_prazo    DateTime?
  membros       MembroProjeto[]
  sprints       Sprint[]
  cards         Card[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("projetos")
}

model MembroProjeto {
  id_membro     String           @id @default(uuid()) @db.Uuid
  id_projeto    String           @db.Uuid
  id_usuario    String           @db.Uuid
  perfil        Perfil           @default(DEV)
  
  projeto       Projeto          @relation(fields: [id_projeto], references: [id_projeto], onDelete: Cascade)
  usuario       Usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([id_projeto, id_usuario])
  @@map("membros_projeto")
}

model Sprint {
  id_sprint     String           @id @default(uuid()) @db.Uuid
  id_projeto    String           @db.Uuid
  nome          String
  data_inicio   DateTime?
  data_fim      DateTime?
  status        StatusSprint     @default(PLANEJAMENTO)
  
  projeto       Projeto          @relation(fields: [id_projeto], references: [id_projeto], onDelete: Cascade)
  cards         Card[]
  logs          LogAcoes[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("sprints")
}

model Card {
  id_card        String           @id @default(uuid()) @db.Uuid
  id_projeto     String           @db.Uuid
  id_sprint      String?          @db.Uuid
  id_responsavel String?          @db.Uuid
  titulo         String
  descricao      String?          @db.Text
  prioridade     Prioridade       @default(MEDIA)
  status         StatusCard       @default(A_FAZER)
  story_points   Int?
  em_risco       Boolean          @default(false)
  deletado_em    DateTime?        @db.Timestamp
  
  projeto        Projeto          @relation(fields: [id_projeto], references: [id_projeto], onDelete: Cascade)
  sprint         Sprint?          @relation(fields: [id_sprint], references: [id_sprint], onDelete: SetNull)
  responsavel    Usuario?         @relation("ResponsavelCards", fields: [id_responsavel], references: [id_usuario], onDelete: SetNull)
  
  anexos         AnexoCard[]
  votos          VotoPoker[]
  notificacoes   Notificacao[]
  logs           LogAcoes[]
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("cards")
}

model AnexoCard {
  id_anexo      String           @id @default(uuid()) @db.Uuid
  id_card       String           @db.Uuid
  nome_arquivo  String
  url_arquivo   String
  tipo_anexo    TipoAnexo
  
  card          Card             @relation(fields: [id_card], references: [id_card], onDelete: Cascade)
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("anexos_card")
}

model VotoPoker {
  id_voto       String           @id @default(uuid()) @db.Uuid
  id_card       String           @db.Uuid
  id_usuario    String           @db.Uuid
  valor         Int
  
  card          Card             @relation(fields: [id_card], references: [id_card], onDelete: Cascade)
  usuario       Usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([id_card, id_usuario])
  @@map("votos_poker")
}

model Notificacao {
  id_notificacao     String      @id @default(uuid()) @db.Uuid
  id_usuario_destino String      @db.Uuid
  id_card_origem     String      @db.Uuid
  mensagem           String
  lida               Boolean     @default(false)
  
  destino            Usuario     @relation("DestinoNotificacoes", fields: [id_usuario_destino], references: [id_usuario], onDelete: Cascade)
  card               Card        @relation(fields: [id_card_origem], references: [id_card], onDelete: Cascade)
  
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@map("notificacoes")
}

model LogAcoes {
  id_log       String            @id @default(uuid()) @db.Uuid
  id_usuario   String            @db.Uuid
  id_card      String?           @db.Uuid
  id_sprint    String?           @db.Uuid
  acao         String
  tipo_acao    TipoAcao
  status_log   String
  
  usuario      Usuario           @relation(fields: [id_usuario], references: [id_usuario], onDelete: Restrict)
  card         Card?             @relation(fields: [id_card], references: [id_card], onDelete: SetNull)
  sprint       Sprint?           @relation(fields: [id_sprint], references: [id_sprint], onDelete: SetNull)
  
  createdAt    DateTime          @default(now())

  @@map("log_acoes")
}
